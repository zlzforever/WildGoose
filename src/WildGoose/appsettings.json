{
  "AllowedHosts": "*",
  "DbContext": {
    "DatabaseType": "PostgreSql",
    "AutoMigrationEnabled": true,
    "TablePrefix": "wild_goose_",
    "UseUnderScoreCase": true,
    "ConnectionString": "User ID=;Password=;Host=10.0.10.190;Port=5432;Database=;Pooling=true;",
    "TableMapper": {
    }
  },
  "WildGoose": {
    "AddUserRoles": [
      "内部添加用户"
    ],
    "UserPropertyMappings": {
      "Title": {
        "Column": "Property01",
        "DisplayName": "职位"
      },
      "EmployeeId": {
        "Column": "Property02",
        "DisplayName": "工号"
      }
    }
  },
  "ApiName": "sample-wildgoose-api",
  "AuthenticationSchemes": "JwtBearer, GatewayJwtBearer",
  "GatewayJwtBearer": {
    "Name": "X-Userinfo",
    "Issuer": "",
    "Audience": ""
  },
  "JwtBearer": {
    "Authority": "http://localhost:8099",
    "RequireHttpsMetadata": false,
    "ValidateAudience": false,
    "ValidateIssuer": false,
    "KeyPath": "jwt.jwk"
  },
  "OpenTelemetry": {
    "Endpoint": "${OTLP_ENDPOINT}",
    "ApiKey": "${OTLP_API_KEY}"
  },
  "Dapr": {
    "pubsub": ""
  },
  "Identity": {
    "Password": {
      "RequireDigit": false,
      "RequireLowercase": false,
      "RequiredLength": 0,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequiredUniqueChars": 1
    },
    "SignIn": {
      "RequireConfirmedEmail": false,
      "RequireConfirmedAccount": false,
      "RequireConfirmedPhoneNumber": false
    },
    "Lockout": {
      "DefaultLockoutTimeSpan": "00:05:00",
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": false
    },
    "User": {
      "AllowedUserNameCharacters": "^[a-zA-Z0-9\u4e00-\u9fa5@]+$",
      "RequireUniqueEmail": false
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Grafana.Loki",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Sinks.Async",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputSocoDB": "{Timestamp:yyyy-MM-dd HH:mm:ss,fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ]
  }
}
